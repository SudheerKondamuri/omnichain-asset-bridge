# Private key for an account funded on both local chains, used for deployment and relaying
# This is the default Anvil/Hardhat account #0 — never use a real key here
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC URLs (used when running outside docker-compose)
CHAIN_A_RPC_URL=http://127.0.0.1:8545
CHAIN_B_RPC_URL=http://127.0.0.1:9545

# Confirmation depth — number of blocks to wait before the relayer acts on an event
CONFIRMATION_DEPTH=3

# Path for relayer SQLite persistence file (inside docker container)
DB_PATH=/usr/src/app/data/relayer.db

# Path where deploy.js writes contract addresses (shared volume)
DATA_PATH=/data/addresses.json
